DTSTAMP:20260628T000000Z
DTSTART:20260630T100000
DURATION:PT20M
RRULE:FREQ=WEEKLY;BYDAY=TU
SUMMARY:Roadwork — PULL day
DESCRIPTION:PULL workout (5-10 min):\nDoorway iso-rows 3x20s (grip the door frame\, lean back\, pull) / Towel rows x12 / Supermans x15 / Reverse snow-angels x12 — 3 rounds.\nAlso: vitamins (with the car key) + water ~80oz = 3 bottles across the day. Brutal-day floor: 20 squats + 10 push-ups (still counts). Log it: https://thecubeographer.github.io/roadwork/
BEGIN:VALARM
ACTION:DISPLAY
TRIGGER:PT0M
DESCRIPTION:Roadwork — PULL day
END:VALARM
END:VEVENT
