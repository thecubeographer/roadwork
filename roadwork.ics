BEGIN:VEVENT
UID:rw-pm-stretch@roadwork
DTSTAMP:20260628T000000Z
DTSTART:20260629T213000
DURATION:PT30M
RRULE:FREQ=DAILY
SUMMARY:Roadwork — nightly stretch + log
DESCRIPTION:5-min IN-BED STRETCH: hips\, hip flexors\, low back\, hamstrings\, spinal twist — undo the day in the seat.\nThen log all 4 in the app + tap Copy for Coach. Did you finish your 3 bottles? https://thecubeographer.github.io/roadwork/
BEGIN:VALARM
ACTION:DISPLAY
TRIGGER:PT0M
DESCRIPTION:Roadwork — nightly stretch + log
