BEGIN:VEVENT
UID:rw-am-mo@roadwork
DTSTAMP:20260628T000000Z
DTSTART:20260629T100000
DURATION:PT20M
RRULE:FREQ=WEEKLY;BYDAY=MO
SUMMARY:Roadwork — PUSH day
DESCRIPTION:PUSH workout (5-10 min):\nPush-ups x12 / Pike push-ups x8 / Chair or bed tricep dips x12 — 3 rounds.\nAlso: vitamins (with the car key) + water ~80oz = 3 bottles across the day. Brutal-day floor: 20 squats + 10 push-ups (still counts). Log it: https://thecubeographer.github.io/roadwork/
BEGIN:VALARM
ACTION:DISPLAY
TRIGGER:PT0M
DESCRIPTION:Roadwork — PUSH day
END:VALARM
END:VEVENT
